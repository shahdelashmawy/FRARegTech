# ============================================================
# FRA RegTech Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# ============================================================
# DATABASE
# ============================================================
# PostgreSQL connection string with pgvector extension
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://fraregtech:password@localhost:5432/fraregtech

# ============================================================
# REDIS (used by Celery task queue)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-secrets-token-hex-32
ALGORITHM=HS256
# Token expiry: 7 days in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================================
# CLAUDE AI (Anthropic)
# ============================================================
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# EMAIL (SMTP) - for alert notifications
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Your Gmail address or other SMTP username
SMTP_USER=your-email@gmail.com
# For Gmail: use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password
# The "From" address shown in sent emails
EMAIL_FROM=FRA RegTech <your-email@gmail.com>

# ============================================================
# TWILIO (WhatsApp alerts)
# ============================================================
# Get credentials from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Twilio WhatsApp sandbox number (use sandbox for testing)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ============================================================
# APPLICATION SETTINGS
# ============================================================
APP_NAME=FRA RegTech
# URL of the frontend (for CORS)
FRONTEND_URL=http://localhost:3000

# ============================================================
# FRA SCRAPER SETTINGS
# ============================================================
FRA_BASE_URL=https://www.fra.gov.eg
# How often to scrape (in hours)
SCRAPE_INTERVAL_HOURS=24

# ============================================================
# FILE UPLOAD SETTINGS
# ============================================================
# Directory to store uploaded documents
UPLOAD_DIR=/app/uploads
# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# ============================================================
# VECTOR SEARCH SETTINGS
# ============================================================
# Embedding dimension (must match the model used)
# paraphrase-multilingual-MiniLM-L12-v2 outputs 384 dimensions
VECTOR_DIMENSION=384
# Number of similar results to retrieve for RAG
TOP_K_RESULTS=5
